# Groq API key (get from https://console.groq.com)
GROQ_API_KEY=gsk_your_api_key_here

# Comma-separated phone numbers with country code (no +)
# Leave empty to reply to everyone
ALLOWED_CONTACTS=919876543210,91XXXXXXXXXX

# Your name (bot will impersonate you)
BOT_NAME=Your Name

# System prompt (use {BOT_NAME} as placeholder)
SYSTEM_PROMPT=You are {BOT_NAME}. Reply naturally — casual, friendly, and brief. Use short WhatsApp-style messages. Don't reveal you are an AI.

# Minutes of idle time before flushing conversation to vector DB
IDLE_FLUSH_MINUTES=5
